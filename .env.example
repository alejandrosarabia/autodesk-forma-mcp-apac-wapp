# ── Autodesk APS App Credentials ──────────────────────────────────
# Get these from https://aps.autodesk.com → My Apps → your app
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# ── OAuth Callback ─────────────────────────────────────────────────
# Must match EXACTLY what you registered in your APS app settings.
# Local dev (default):
APS_CALLBACK_URL=http://localhost:3001/callback
# Railway / cloud deployment — uncomment and set your Railway public URL:
# APS_CALLBACK_URL=https://<your-app>.up.railway.app/auth/callback

# ── Railway: token bootstrap & persistence ─────────────────────────
# APS_3LO_TOKEN: paste the JSON contents of .aps_3lo_token.json here
# to bootstrap the server on first deploy (or after token expiry).
# Generate locally with: node auth-trigger.js
# Then copy the full JSON of .aps_3lo_token.json as a single line.
# APS_3LO_TOKEN={"access_token":"...","refresh_token":"...","expires_at":...}
#
# APS_TOKEN_FILE: path to a persistent volume so refreshed tokens survive
# redeploys. Set this if you have a Railway volume mounted at /data.
# APS_TOKEN_FILE=/data/.aps_3lo_token.json

# ── Scopes ─────────────────────────────────────────────────────────
APS_SCOPES=data:read data:write data:create account:read account:write

# ── Region ─────────────────────────────────────────────────────────
# US = Americas, EMEA = Europe/Middle East/Africa, APAC = Asia Pacific
# Check your ACC account region in ACC Admin settings
APS_REGION=US

# ── Account ID ─────────────────────────────────────────────────────
# Your ACC Account/Hub ID
# How to find it: log into ACC → Admin → the URL contains your account ID
# Looks like: a.YWNjb3VudC1pZC0xMjM0NTY3
APS_ACCOUNT_ID=your_account_id_here

# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────
# Get these from Meta Business Manager → WhatsApp → API Setup:
#   https://developers.facebook.com/apps/
META_WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxx
META_WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Pick any secret string; you'll paste the same value into the Meta
# webhook config when registering the callback URL.
META_WHATSAPP_VERIFY_TOKEN=choose-a-random-secret
# Optional — defaults to v21.0 if unset
META_WHATSAPP_API_VERSION=v21.0

# Comma-separated whitelist in E.164 format (with or without leading +).
# Numbers NOT in this list are silently ignored.
WHATSAPP_ALLOWED_NUMBERS=+34612345678,+15551234567

# Shared with the Telegram bot — needed by the Claude agent loop.
ANTHROPIC_API_KEY=sk-ant-...
