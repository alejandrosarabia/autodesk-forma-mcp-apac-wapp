{
  "openapi": "3.0.0",
  "info": {
    "title": "Autodesk Construction Cloud MCP API",
    "description": "REST wrapper around the Autodesk Construction Cloud MCP server. Every tool is exposed as a POST endpoint. Authenticate with the x-api-key header.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://YOUR-RAILWAY-APP.up.railway.app",
      "description": "Railway deployment (replace with your actual Railway URL)"
    }
  ],
  "security": [
    { "ApiKeyAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "ToolResult": {
        "type": "object",
        "description": "JSON result returned by the tool"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "PermissionEntry": {
        "type": "object",
        "required": ["subjectId", "subjectType", "actions"],
        "properties": {
          "subjectId": {
            "type": "string",
            "description": "userId, roleId, or companyId"
          },
          "subjectType": {
            "type": "string",
            "enum": ["USER", "ROLE", "COMPANY"]
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["VIEW", "DOWNLOAD", "UPLOAD", "COLLABORATE", "CONTROL"]
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/check_auth_status": {
      "post": {
        "operationId": "check_auth_status",
        "summary": "Check Autodesk authentication status",
        "description": "Check the current Autodesk authentication status. Returns whether a valid 3LO token exists, when it expires, and whether a re-auth is needed before making API calls.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": {} }
            }
          }
        },
        "responses": {
          "200": { "description": "Auth status", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/start_auth_flow": {
      "post": {
        "operationId": "start_auth_flow",
        "summary": "Start Autodesk OAuth browser authentication flow",
        "description": "Start the Autodesk OAuth browser authentication flow. Returns a URL the user must open in their browser to log in.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": {} }
            }
          }
        },
        "responses": {
          "200": { "description": "Auth flow started with URL", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/get_hubs": {
      "post": {
        "operationId": "get_hubs",
        "summary": "Get all accessible Autodesk hubs",
        "description": "Get all accessible Autodesk hubs (BIM 360 / ACC accounts).",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": {} }
            }
          }
        },
        "responses": {
          "200": { "description": "List of hubs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/get_projects": {
      "post": {
        "operationId": "get_projects",
        "summary": "Get all projects within a hub",
        "description": "Get all projects within a hub.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["hubId"],
                "properties": {
                  "hubId": { "type": "string", "description": "Hub ID (from get_hubs)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "List of projects", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
