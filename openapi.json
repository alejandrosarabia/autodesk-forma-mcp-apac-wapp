    "/api/search_folder": {
      "post": {
        "operationId": "search_folder",
        "summary": "Search for items by name within a folder",
        "description": "Search for items by name within a folder.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["projectId", "folderId", "query"],
                "properties": {
                  "projectId": { "type": "string", "description": "Project ID" },
                  "folderId": { "type": "string", "description": "Folder URN/ID to search within" },
                  "query": { "type": "string", "description": "Name substring to search for" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Matching items", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
