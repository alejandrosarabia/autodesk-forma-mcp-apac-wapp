              }
            }
          }
        },
        "responses": {
          "200": { "description": "List of top-level folders", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "401": { "description": "Invalid or missing x-api-key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
